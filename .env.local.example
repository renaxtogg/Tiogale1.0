# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — Settings > API in your Supabase dashboard
# IMPORTANT: URL must be the BASE project URL (no /rest/v1/ suffix)
# Example: https://abcdefghijklmno.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase publishable (anon) key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — NEVER expose in the browser or commit to git
# Used only in server-side scripts (migrations, seeding, admin tasks)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App base URL — used for OAuth callbacks and email confirmation links
# In production, set this to your Vercel deployment URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
